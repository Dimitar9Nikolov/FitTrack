@model FitTrack.Models.Exercise
@{ ViewData["Title"] = "Delete Exercise"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">← Back</a>
    <h2 class="fw-bold mb-0">Delete Exercise</h2>
</div>

<div class="card shadow-sm border-danger" style="max-width: 480px;">
    <div class="card-body p-4">
        <p class="mb-3">Are you sure you want to delete this exercise?</p>
        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">Muscle Group</dt>
            <dd class="col-sm-8">@Model.MuscleGroup</dd>
            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8">@Model.Category.Name</dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" name="id" value="@Model.Id"/>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
