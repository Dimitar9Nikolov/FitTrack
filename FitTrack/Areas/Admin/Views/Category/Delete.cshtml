@model CategoryFormViewModel
@{ ViewData["Title"] = "Delete Category"; }

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">← Back</a>
    <h2 class="fw-bold mb-0">Delete Category</h2>
</div>

<div class="card shadow-sm border-danger" style="max-width: 480px;">
    <div class="card-body p-4">
        <p class="mb-2">Are you sure you want to delete this category?</p>
        <p class="mb-1"><strong>Name:</strong> @Model.Name</p>
        <p class="mb-3">
            <strong>Exercises linked:</strong>
            <span class="badge bg-@(Model.ExerciseCount > 0 ? "danger" : "secondary")">@Model.ExerciseCount</span>
        </p>

        @if (Model.ExerciseCount > 0)
        {
            <div class="alert alert-warning py-2">
                All @Model.ExerciseCount exercise(s) in this category will also be deleted.
            </div>
        }

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id"/>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
