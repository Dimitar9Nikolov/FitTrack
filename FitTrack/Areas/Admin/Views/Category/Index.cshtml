@model IEnumerable<CategoryFormViewModel>
@{ ViewData["Title"] = "Categories"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Categories</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Category</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Name</th>
                <th class="text-center">Exercises</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td class="text-muted">@cat.Id</td>
                    <td class="fw-medium">@cat.Name</td>
                    <td class="text-center">
                        <span class="badge bg-secondary">@cat.ExerciseCount</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@cat.Id"
                           class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <a asp-action="Delete" asp-route-id="@cat.Id"
                           class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">No categories yet.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
