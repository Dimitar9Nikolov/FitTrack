@{
    ViewData["Title"] = "Server Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center py-5">
    <div class="display-1 fw-bold text-danger mb-3">500</div>
    <h2 class="fw-bold mb-2">Something Went Wrong</h2>
    <p class="text-muted lead mb-4">
        An unexpected error occurred on our end. Please try again in a moment.
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
        Back to Home
    </a>
</div>
