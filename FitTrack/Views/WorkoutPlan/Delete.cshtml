@model FitTrack.ViewModels.WorkoutPlan.WorkoutPlanDetailsViewModel
@{ 
    ViewData["Title"] = "Delete Workout Plan";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary me-3">← Back</a>
    <h2 class="fw-bold mb-0">Delete Workout Plan</h2>
</div>

<div class="card shadow-sm border-danger" style="max-width:500px;">
    <div class="card-body p-4">
        <p class="mb-3">Are you sure you want to delete this plan? This cannot be undone.</p>

        <dl class="row">
            <dt class="col-sm-4">Title</dt>
            <dd class="col-sm-8">@Model.Title</dd>
            <dt class="col-sm-4">Difficulty</dt>
            <dd class="col-sm-8">@Model.Difficulty</dd>
            <dt class="col-sm-4">Created by</dt>
            <dd class="col-sm-8">@Model.CreatorName</dd>
            <dt class="col-sm-4">Workouts logged</dt>
            <dd class="col-sm-8">@Model.WorkoutCount</dd>
        </dl>

        @if (Model.WorkoutCount > 0)
        {
            <div class="alert alert-warning py-2">
                @Model.WorkoutCount workout(s) linked to this plan will be unlinked (not deleted).
            </div>
        }

        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" name="id" value="@Model.Id"/>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
