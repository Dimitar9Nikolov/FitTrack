@model FitTrack.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div class="display-1 fw-bold text-danger mb-3">⚠️</div>
    <h2 class="fw-bold mb-2">An Error Occurred</h2>
    <p class="text-muted lead mb-4">Something went wrong while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Home</a>
</div>
