@model FitTrack.ViewModels.Exercise.ExerciseDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">← Exercises</a>
    <h2 class="fw-bold mb-0">@Model.Name</h2>
</div>

<div class="row g-4">
    @* Left: image *@
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name"
                 class="img-fluid rounded shadow-sm w-100" style="max-height:300px;object-fit:cover;"/>
        }
        else
        {
            <div class="bg-light rounded d-flex align-items-center justify-content-center shadow-sm"
                 style="height:200px;">
                <span class="display-3">
                    @(Model.ExerciseType == "Cardio" ? "🏃" :
                      Model.ExerciseType == "Flexibility" ? "🧘" : "🏋️")
                </span>
            </div>
        }
    </div>

    @* Right: details *@
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge @TypeBadgeClass(Model.ExerciseType) fs-6">@Model.ExerciseType</span>
                    <span class="badge bg-light text-dark border fs-6">@Model.CategoryName</span>
                </div>

                <table class="table table-borderless table-sm mb-4" style="max-width:400px">
                    <tr>
                        <th class="text-muted fw-normal ps-0" style="width:140px">Muscle Group</th>
                        <td class="fw-medium">@Model.MuscleGroup</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal ps-0">Times Logged</th>
                        <td class="fw-medium">@Model.TimesLoggedByUsers</td>
                    </tr>
                </table>

                <h6 class="fw-bold mb-2">Description</h6>
                <p class="text-muted">@Model.Description</p>

                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Workout" asp-action="Create"
                       class="btn btn-primary mt-2">+ Log a Workout</a>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    static string TypeBadgeClass(string type) => type switch
    {
        "Cardio"      => "bg-info text-dark",
        "Flexibility" => "bg-success",
        _             => "bg-primary"
    };
}
