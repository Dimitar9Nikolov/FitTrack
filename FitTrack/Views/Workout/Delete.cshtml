@model FitTrack.ViewModels.Workout.WorkoutListItemViewModel
@{
    ViewData["Title"] = "Delete Workout";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary me-3">← Back</a>
    <h2 class="fw-bold mb-0">Delete Workout</h2>
</div>

<div class="card shadow-sm border-danger" style="max-width:480px;">
    <div class="card-body p-4">
        <p class="mb-3">Are you sure you want to delete this workout? All logged exercises will also be removed.</p>

        <dl class="row">
            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8">@Model.Date.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Duration</dt>
            <dd class="col-sm-8">@Model.DurationMinutes min</dd>
            <dt class="col-sm-4">Exercises</dt>
            <dd class="col-sm-8">@Model.ExerciseCount</dd>
            @if (Model.WorkoutPlanTitle != null)
            {
                <dt class="col-sm-4">Plan</dt>
                <dd class="col-sm-8">@Model.WorkoutPlanTitle</dd>
            }
        </dl>

        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" name="id" value="@Model.Id"/>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
