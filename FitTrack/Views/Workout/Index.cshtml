@model IEnumerable<FitTrack.ViewModels.Workout.WorkoutListItemViewModel>
@{ ViewData["Title"] = "My Workouts"; }


<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">My Workouts</h2>
    <a asp-action="Create" class="btn btn-primary">+ Log Workout</a>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p class="fs-5">No workouts logged yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary mt-2">Log your first workout!</a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Duration</th>
                    <th>Exercises</th>
                    <th>Plan</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var w in Model)
                {
                    <tr>
                        <td class="fw-medium">@w.Date.ToString("dd MMM yyyy")</td>
                        <td>@w.DurationMinutes min</td>
                        <td><span class="badge bg-secondary">@w.ExerciseCount</span></td>
                        <td>
                            @if (w.WorkoutPlanTitle != null)
                            {
                                <span class="badge bg-light text-dark border">@w.WorkoutPlanTitle</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-muted small">
                            @(w.Notes?.Length > 40 ? w.Notes[..40] + "…" : w.Notes ?? "—")
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@w.Id"
                               class="btn btn-sm btn-outline-primary me-1">View</a>
                            <a asp-action="Edit" asp-route-id="@w.Id"
                               class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                            <a asp-action="Delete" asp-route-id="@w.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
