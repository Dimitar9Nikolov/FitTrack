@model FitTrack.ViewModels.Workout.WorkoutDetailsViewModel
@{ ViewData["Title"] = $"Workout — {Model.Date:dd MMM yyyy}"; }


<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">← My Workouts</a>
    <h2 class="fw-bold mb-0">@Model.Date.ToString("dddd, dd MMM yyyy")</h2>
</div>

<div class="row g-4">

    <!-- Left: info + exercise list -->
    <div class="col-lg-8">

        <!-- Workout summary -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="row text-center g-3">
                    <div class="col">
                        <div class="fs-3 fw-bold text-primary">@Model.DurationMinutes</div>
                        <div class="text-muted small">minutes</div>
                    </div>
                    <div class="col">
                        <div class="fs-3 fw-bold text-success">@Model.Exercises.Count</div>
                        <div class="text-muted small">exercises</div>
                    </div>
                    @if (Model.WorkoutPlanTitle != null)
                    {
                        <div class="col">
                            <div class="fw-bold">
                                <a asp-controller="WorkoutPlan" asp-action="Details"
                                   asp-route-id="@Model.WorkoutPlanId">@Model.WorkoutPlanTitle</a>
                            </div>
                            <div class="text-muted small">plan</div>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr/>
                    <p class="mb-0 text-muted"><em>@Model.Notes</em></p>
                }
            </div>
        </div>

        <!-- Exercise list -->
        <h5 class="fw-bold mb-3">Exercises Logged</h5>

        @if (!Model.Exercises.Any())
        {
            <div class="alert alert-info">No exercises added yet — use the form on the right to add some!</div>
        }
        else
        {
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                        <tr>
                            <th>Exercise</th>
                            <th>Muscle</th>
                            <th>Sets / Details</th>
                            <th style="width:50px"></th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var ex in Model.Exercises)
                        {
                            <tr>
                                <td class="fw-medium">
                                    @ex.ExerciseName
                                    @if (ex.ExerciseType == "Cardio")
                                    { <span class="badge bg-info text-dark ms-1">Cardio</span> }
                                </td>
                                <td><span class="badge bg-light text-dark border">@ex.MuscleGroup</span></td>
                                <td>
                                    @if (ex.ExerciseType == "Cardio")
                                    {
                                        <span class="text-muted small">
                                            @(ex.CardioMinutes.HasValue ? $"{ex.CardioMinutes} min" : "—")
                                            @if (ex.SpeedKmh is > 0) { <text> · @ex.SpeedKmh km/h</text> }
                                            @if (ex.Incline is > 0)  { <text> · @ex.Incline% incline</text> }
                                        </span>
                                    }
                                    else if (ex.Sets.Any())
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var s in ex.Sets)
                                            {
                                                <span class="badge bg-secondary">
                                                    @s.Reps reps@(s.WeightKg > 0 ? $" · {s.WeightKg}kg" : " BW")
                                                </span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No sets logged</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="RemoveExercise" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ex.Id"/>
                                        <input type="hidden" name="workoutId" value="@Model.Id"/>
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Remove this exercise?')">✕</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- Right: Add exercise form -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 sticky-top" style="top:1rem;">
            <div class="card-header bg-primary text-white fw-bold">Add Exercise</div>
            <div class="card-body p-3">
                <form asp-action="AddExercise" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AddExerciseForm.WorkoutId"/>

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Exercise</label>
                        <select id="exerciseSelect"
                                asp-for="AddExerciseForm.ExerciseId"
                                asp-items="Model.AddExerciseForm.Exercises"
                                class="form-select form-select-sm">
                            <option value="">— pick exercise —</option>
                        </select>
                    </div>

                    <!-- Strength: per-set table -->
                    <div id="strengthFields">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="form-label small fw-medium mb-0">Sets</span>
                            <button type="button" class="btn btn-sm btn-outline-success py-0 px-2"
                                    onclick="addSet()">+ Set</button>
                        </div>
                        <table class="table table-sm mb-2" id="setsTable">
                            <thead>
                            <tr class="text-muted small">
                                <th style="width:28px">#</th>
                                <th>Reps</th>
                                <th>kg</th>
                                <th style="width:28px"></th>
                            </tr>
                            </thead>
                            <tbody id="setsContainer">
                            @for (int i = 0; i < Model.AddExerciseForm.SetData.Count; i++)
                            {
                                <tr class="set-row">
                                    <td class="text-muted small align-middle">
                                        <span class="set-number">@(i + 1)</span>
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="AddExerciseForm.SetData[@i].Reps"
                                               value="@Model.AddExerciseForm.SetData[i].Reps"
                                               class="form-control form-control-sm"
                                               style="width:70px" min="1" max="1000"/>
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="AddExerciseForm.SetData[@i].WeightKg"
                                               value="@Model.AddExerciseForm.SetData[i].WeightKg"
                                               step="0.5"
                                               class="form-control form-control-sm"
                                               style="width:75px" min="0" max="1000"/>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger py-0 px-1"
                                                onclick="removeSet(this)">✕</button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>

                    <!-- Cardio fields -->
                    <div id="cardioFields" style="display:none;">
                        <div class="mb-2">
                            <label class="form-label small fw-medium">Duration (min)</label>
                            <input asp-for="AddExerciseForm.CardioMinutes" type="number"
                                   class="form-control form-control-sm" min="1" max="600"/>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium">Speed (km/h)</label>
                                <input asp-for="AddExerciseForm.SpeedKmh" type="number" step="0.5"
                                       class="form-control form-control-sm" min="0" max="100"/>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium">Incline (%)</label>
                                <input asp-for="AddExerciseForm.Incline" type="number" step="0.5"
                                       class="form-control form-control-sm" min="0" max="30"/>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100 mt-1">+ Add</button>
                </form>
            </div>
        </div>

        <!-- Quick actions -->
        <div class="mt-3 d-grid gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit Workout</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete Workout</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Exercise type toggle ───────────────────────────────────────────────
        const exerciseTypeMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AddExerciseForm.ExerciseTypeMap));
        const exerciseSelect  = document.getElementById('exerciseSelect');
        const strengthFields  = document.getElementById('strengthFields');
        const cardioFields    = document.getElementById('cardioFields');

        function toggleFields() {
            const type = exerciseTypeMap[parseInt(exerciseSelect.value)] ?? 'Strength';
            strengthFields.style.display = type === 'Cardio' ? 'none' : '';
            cardioFields.style.display   = type === 'Cardio' ? ''     : 'none';
        }

        exerciseSelect.addEventListener('change', toggleFields);
        toggleFields();

        // ── Dynamic set rows ──────────────────────────────────────────────────
        function addSet() {
            const tbody = document.getElementById('setsContainer');
            const idx   = tbody.querySelectorAll('.set-row').length;
            const tr    = document.createElement('tr');
            tr.className = 'set-row';
            tr.innerHTML = `
                <td class="text-muted small align-middle"><span class="set-number">${idx + 1}</span></td>
                <td><input type="number" name="AddExerciseForm.SetData[${idx}].Reps" value="10"
                           class="form-control form-control-sm" style="width:70px" min="1" max="1000"></td>
                <td><input type="number" name="AddExerciseForm.SetData[${idx}].WeightKg" value="0" step="0.5"
                           class="form-control form-control-sm" style="width:75px" min="0" max="1000"></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger py-0 px-1"
                            onclick="removeSet(this)">✕</button></td>
            `;
            tbody.appendChild(tr);
        }

        function removeSet(btn) {
            btn.closest('.set-row').remove();
            renumberSets();
        }

        function renumberSets() {
            document.querySelectorAll('#setsContainer .set-row').forEach((row, idx) => {
                row.querySelector('.set-number').textContent = idx + 1;
                row.querySelector('input[name$=".Reps"]').name    = `AddExerciseForm.SetData[${idx}].Reps`;
                row.querySelector('input[name$=".WeightKg"]').name = `AddExerciseForm.SetData[${idx}].WeightKg`;
            });
        }
    </script>
}
