@model FitTrack.ViewModels.Workout.WorkoutFormViewModel
@{
    ViewData["Title"] = "Log Workout";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">← Back</a>
    <h2 class="fw-bold mb-0">Log a Workout</h2>
</div>

<div class="card shadow-sm border-0" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-7">
                    <label asp-for="Date" class="form-label fw-medium"></label>
                    <input asp-for="Date" type="date" class="form-control"/>
                    <span asp-validation-for="Date" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="DurationMinutes" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <input asp-for="DurationMinutes" type="number" class="form-control" min="1" max="600"/>
                        <span class="input-group-text">min</span>
                    </div>
                    <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="WorkoutPlanId" class="form-label fw-medium"></label>
                <select asp-for="WorkoutPlanId" asp-items="Model.WorkoutPlans" class="form-select">
                    <option value="">— No plan —</option>
                </select>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-medium">Notes <span class="text-muted fw-normal">(optional)</span></label>
                <textarea asp-for="Notes" class="form-control" rows="3"
                          placeholder="How did it go? Any PRs?"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Start Logging</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial"/> }
