@model FitTrack.ViewModels.Stats.StatsViewModel
@{ ViewData["Title"] = "My Stats"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">My Stats</h2>
    <a asp-controller="Workout" asp-action="Create" class="btn btn-primary">+ Log Workout</a>
</div>

<!-- Overview cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fs-2 fw-bold text-primary">@Model.TotalWorkouts</div>
            <div class="text-muted small">Total Workouts</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fs-2 fw-bold text-success">@Model.TotalExercisesLogged</div>
            <div class="text-muted small">Exercises Logged</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fs-2 fw-bold text-info">@(Model.TotalDurationMinutes / 60)h @(Model.TotalDurationMinutes % 60)m</div>
            <div class="text-muted small">Total Time</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fs-2 fw-bold text-warning">@Model.WorkoutsThisWeek</div>
            <div class="text-muted small">This Week</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fs-2 fw-bold text-secondary">@Model.WorkoutsThisMonth</div>
            <div class="text-muted small">This Month</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-3 h-100">
            <div class="fw-bold text-danger small">@(Model.FavoriteMuscleGroup ?? "—")</div>
            <div class="text-muted small">Top Muscle</div>
            <div class="fw-bold text-dark small mt-1">@(Model.FavoriteExercise ?? "—")</div>
            <div class="text-muted small">Top Exercise</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Monthly chart -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-bold border-0 pt-3">Workouts — Last 6 Months</div>
            <div class="card-body">
                <canvas id="monthlyChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <!-- Top exercises table -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-bold border-0 pt-3">Top Exercises</div>
            <div class="card-body p-0">
                @if (!Model.TopExercises.Any())
                {
                    <p class="text-muted text-center py-4">No exercises logged yet.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Exercise</th>
                            <th>Muscle</th>
                            <th class="text-center">Times</th>
                            <th class="text-end">Volume (kg)</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var ex in Model.TopExercises)
                        {
                            <tr>
                                <td class="fw-medium">@ex.ExerciseName</td>
                                <td><span class="badge bg-light text-dark border">@ex.MuscleGroup</span></td>
                                <td class="text-center">@ex.TimesLogged</td>
                                <td class="text-end">@(ex.TotalVolume > 0 ? $"{ex.TotalVolume:F0}" : "BW")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<!-- Monthly breakdown table -->
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-transparent fw-bold border-0 pt-3">Monthly Breakdown</div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead class="table-light">
            <tr>
                <th>Month</th>
                <th class="text-center">Workouts</th>
                <th class="text-center">Total Time</th>
                <th class="text-center">Avg Duration</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.MonthlyData)
            {
                <tr class="@(m.WorkoutCount == 0 ? "text-muted" : "")">
                    <td>@m.Month</td>
                    <td class="text-center">
                        @if (m.WorkoutCount > 0)
                        {
                            <span class="badge bg-primary">@m.WorkoutCount</span>
                        }
                        else { <span>—</span> }
                    </td>
                    <td class="text-center">
                        @if (m.TotalMinutes > 0)
                        { @($"{m.TotalMinutes / 60}h {m.TotalMinutes % 60}m") }
                        else { <span>—</span> }
                    </td>
                    <td class="text-center">
                        @if (m.WorkoutCount > 0)
                        { @($"{m.TotalMinutes / m.WorkoutCount} min") }
                        else { <span>—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('monthlyChart');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.MonthlyData.Select(m => $"'{m.Month}'")))],
                datasets: [{
                    label: 'Workouts',
                    data: [@string.Join(",", Model.MonthlyData.Select(m => m.WorkoutCount))],
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderColor: 'rgba(13, 110, 253, 1)',
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 }
                    }
                }
            }
        });
    </script>
}
